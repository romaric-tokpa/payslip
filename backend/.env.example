# Copier ce fichier :  cp .env.example .env
# Prisma lit DATABASE_URL via prisma.config.ts (dotenv).
#
# Postgres Docker (racine du repo) : docker compose up -d postgres
# Identifiants alignés sur docker-compose.yml : user payslip / mdp payslip / DB payslip

DATABASE_URL="postgresql://payslip:payslip@localhost:5433/payslip?schema=public"
REDIS_URL="redis://localhost:6379"

S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="payslip-manager"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

JWT_SECRET="changez-moi-en-production"
JWT_REFRESH_SECRET="changez-moi-aussi"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_DAYS="7"

# Optionnel
# PORT=3000

# Origines CORS autorisées (séparées par des virgules)
# CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Throttling global (requêtes par fenêtre, fenêtre en secondes)
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100

# Firebase Cloud Messaging (push). Sans ce chemin : notifications in-app uniquement.
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
