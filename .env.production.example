# Exemple pour docker-compose.prod.yml (copier vers .env à la racine du repo)

POSTGRES_DB=payslip
POSTGRES_USER=payslip
POSTGRES_PASSWORD=changez-moi

REDIS_PASSWORD=changez-moi-redis

# S3, JWT, CORS, THROTTLE, FIREBASE, etc. — alignés sur backend/.env.example
# DATABASE_URL et REDIS_URL sont surchargés par docker-compose.prod.yml pour les services internes.
