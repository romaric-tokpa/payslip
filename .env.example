# Modèle d’environnement — à copier vers backend/.env :
#   cp .env.example backend/.env
# (ou depuis backend/ : cp .env.example .env si vous utilisez backend/.env.example)

DATABASE_URL="postgresql://payslip:payslip@localhost:5433/payslip?schema=public"
REDIS_URL="redis://localhost:6379"

# MinIO / S3 — API :9000, console :9001 (docker-compose)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="payslip-manager"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

JWT_SECRET="changez-moi-en-production"
JWT_REFRESH_SECRET="changez-moi-aussi"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_DAYS="7"
